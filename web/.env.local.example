# CSPR.click app id, register a real app at https://cspr.click
NEXT_PUBLIC_CSPR_CLICK_APP_ID=

# Agent server (see ../agent), POST /api/payout-check
NEXT_PUBLIC_AGENT_URL=http://localhost:4020

# Deployed ParametricPolicy contract hash (client-side, used to build submit_reading deploys)
NEXT_PUBLIC_CONTRACT_HASH=

# Same contract hash, read server-side by app/api/events/route.ts
CONTRACT_HASH=

# CSPR.cloud access token, server-only, never exposed to the client
CSPR_CLOUD_ACCESS_KEY=
